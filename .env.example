# Agent Manager Plugin Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Service Ports
# =============================================================================
DASHBOARD_PORT=9005

# =============================================================================
# Directory Paths
# =============================================================================
# Path to topology data directory (where topology.json files are stored)
TOPOLOGY_DATA_DIR=./topologies

# Path to outputs directory (for Trident compatibility)
OUTPUTS_DIR=/tmp/outputs

# =============================================================================
# Network Topology Plugin
# =============================================================================
# URL of the network-topology plugin service
TOPOLOGY_PLUGIN_URL=http://scl-network-topology:9002

# =============================================================================
# State Management
# =============================================================================
# Path to agent state file
AGENT_STATE_FILE=/app/state/agent_state.json
AGENT_STATE_PATH=/app/state/agent_state.json

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Docker Compose
# =============================================================================
COMPOSE_FILE=/app/docker-compose.yml

# =============================================================================
# Optional: External Services
# =============================================================================
# LLM configuration (for OpenCode agents)
OPENCODE_API_KEY=your-api-key-here
LLM_URL=https://llm.ai.e-infra.cz/v1
LLM_MODEL=gemma4
