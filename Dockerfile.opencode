ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE} as base

# Install dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip curl sudo sqlite3 \
    && pip3 install --no-cache-dir requests \
    && rm -rf /var/lib/apt/lists/*

# Create required directories
RUN mkdir -p /root/.config/opencode /root/.local/share/opencode /opt/agents /var/log/agent

# Create labuser for SSH access
RUN useradd -m -s /bin/bash labuser && \
    echo "labuser ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/labuser && \
    chmod 440 /etc/sudoers.d/labuser

# Create a mock OpenCode health endpoint script
RUN echo '#!/bin/bash\n\
echo "{\"status\": \"ready\"}"\n\
' > /usr/local/bin/opencode-health && \
    chmod +x /usr/local/bin/opencode-health

# Expose OpenCode port
EXPOSE 4096

# Set up a simple health check
HEALTHCHECK --interval=5s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:4096/health || exit 1

CMD ["/bin/bash"]
